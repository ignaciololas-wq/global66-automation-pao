{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/index.js": {
      "maxDuration": 30,
      "includeFiles": "public/**"
    }
  },
  "rewrites": [
    { "source": "/", "destination": "/index.html" },
    { "source": "/admin", "destination": "/admin.html" },
    { "source": "/dashboard", "destination": "/dashboard.html" },
    { "source": "/p/:token*", "destination": "/provider.html" },
    { "source": "/health", "destination": "/api" },
    { "source": "/digest", "destination": "/api" },
    { "source": "/run", "destination": "/api" },
    { "source": "/run-alertas", "destination": "/api" },
    { "source": "/extract", "destination": "/api" },
    { "source": "/sanctions", "destination": "/api" },
    { "source": "/hito1-semaforo", "destination": "/api" },
    { "source": "/slack-callback", "destination": "/api" },
    { "source": "/validate-checklist", "destination": "/api" },
    { "source": "/providers", "destination": "/api" },
    { "source": "/providers/status", "destination": "/api" },
    { "source": "/contracts", "destination": "/api" },
    { "source": "/contracts/sign", "destination": "/api" },
    { "source": "/api/intake", "destination": "/api" },
    { "source": "/api/intake/approve", "destination": "/api" },
    { "source": "/api/provider", "destination": "/api" },
    { "source": "/api/provider/fill", "destination": "/api" },
    { "source": "/api/provider/upload", "destination": "/api" },
    { "source": "/api/sociedades", "destination": "/api" },
    { "source": "/api/admin/users", "destination": "/api" },
    { "source": "/api/admin/users/role", "destination": "/api" },
    { "source": "/api/auth/magic-link", "destination": "/api" },
    { "source": "/api/auth/login", "destination": "/api" }
  ],
  "headers": [
    {
      "source": "/admin",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate, max-age=0" },
        { "key": "Pragma", "value": "no-cache" }
      ]
    },
    {
      "source": "/admin.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate, max-age=0" }
      ]
    }
  ]
}
