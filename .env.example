# ── Modo ────────────────────────────────────────────────────────────────────
# true = todos los servicios externos retornan datos fake.
# Útil para probar pipeline end-to-end sin creds reales.
MOCK_MODE=false

# ── Slack ──────────────────────────────────────────────────────────────────
# Bot OAuth Token + Signing Secret (HTTP callbacks Stack A)
SLACK_BOT_TOKEN=xoxb-xxx
SLACK_SIGNING_SECRET=
# App Token solo si usás Socket Mode (legacy Stack B)
SLACK_APP_TOKEN=xapp-xxx
# Canales aprobación (channel ID, no nombre)
SLACK_COMPLIANCE_CHANNEL=C0XXXXXXXXXX
SLACK_LEGAL_CHANNEL=C0XXXXXXXXXX
SLACK_ADMIN_CHANNEL=C0XXXXXXXXXX

# ── Supabase ────────────────────────────────────────────────────────────────
SUPABASE_URL=https://kdhpbrpeneokvhwyxmwn.supabase.co
# Legacy anon key (Stack B usaba esta)
SUPABASE_KEY=
# service_role para server Stack A (bypassea RLS)
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PUBLISHABLE_KEY=sb_publishable_gMuIUc-TW3cBMQMXT3Tcfw_OnFQHbs-

# ── Finnecto ────────────────────────────────────────────────────────────────
# REST API: Authorization: Bearer <FINNECTO_API_KEY>
# Docs: https://finnecto-api.readme.io | Base: https://api.finnecto.com
# Generar API key: Administración → Ajustes (hasta 5 keys por cliente)
FINNECTO_BASE_URL=https://api.finnecto.com
FINNECTO_API_KEY=
# Sandbox alternativo: http://sandbox.finnecto.com

# ── Finecto (legacy Stack B — solo si reusás Playwright UI) ─────────────────
FINECTO_URL=
FINECTO_USER=
FINECTO_PASSWORD=

# ── Gemini (Google AI) ──────────────────────────────────────────────────────
# Generar key en https://aistudio.google.com/apikey (free tier disponible)
GEMINI_API_KEY=
# pro = extracción contratos. flash = análisis TC (más barato).
GEMINI_MODEL=gemini-2.5-pro
GEMINI_MODEL_FLASH=gemini-2.5-flash
# Alias aceptado: GOOGLE_API_KEY

# ── Google Workspace (solo Drive — el form es nativo en la plataforma) ─────
GOOGLE_DRIVE_ROOT_FOLDER=
GOOGLE_SERVICE_ACCOUNT_JSON=./secrets/gsa.json

# ── SignNow ─────────────────────────────────────────────────────────────────
SIGNNOW_CLIENT_ID=
SIGNNOW_CLIENT_SECRET=
SIGNNOW_USERNAME=
SIGNNOW_PASSWORD=
SIGNNOW_TEMPLATE_ID=

# ── Resend (email transaccional) ────────────────────────────────────────────
# https://resend.com → free 3k/mes
# Mientras no exista, server loguea mock email a stdout.
RESEND_API_KEY=
RESEND_FROM=Global66 Contratos <contratos@global66.com>

# ── OpenSanctions ───────────────────────────────────────────────────────────
OPENSANCTIONS_API_KEY=

# ── n8n / Server ────────────────────────────────────────────────────────────
N8N_WEBHOOK_BASE=https://c204.app.n8n.cloud/webhook
N8N_BASE_URL=https://c204.app.n8n.cloud
SERVER_BASE=http://server:3000
PORT=3000

# ── Notion ──────────────────────────────────────────────────────────────────
NOTION_API_KEY=
NOTION_DB_PROYECTOS=8ee9db22-f903-49b0-bb72-4a9b5722996b
NOTION_DB_TAREAS=3ced4d8e-e89a-4a06-83e7-0cba854f609c
