# ── Modo ────────────────────────────────────────────────────────────────────
# true = todos los servicios externos retornan datos fake.
# Útil para probar pipeline end-to-end sin creds reales.
MOCK_MODE=false

# ── Slack ──────────────────────────────────────────────────────────────────
# Bot OAuth Token + Signing Secret (HTTP callbacks Stack A)
SLACK_BOT_TOKEN=xoxb-xxx
SLACK_SIGNING_SECRET=
# App Token solo si usás Socket Mode (legacy Stack B)
SLACK_APP_TOKEN=xapp-xxx
# Canales aprobación (channel ID, no nombre)
SLACK_COMPLIANCE_CHANNEL=C0XXXXXXXXXX
SLACK_LEGAL_CHANNEL=C0XXXXXXXXXX
SLACK_ADMIN_CHANNEL=C0XXXXXXXXXX
# Fallback opcional: si alguno de los 3 anteriores está vacío, usa este channel ID común.
# Útil al arrancar — todas las aprobaciones llegan a un solo canal temporal.
SLACK_DEFAULT_CHANNEL=C0XXXXXXXXXX

# ── Supabase ────────────────────────────────────────────────────────────────
SUPABASE_URL=https://kdhpbrpeneokvhwyxmwn.supabase.co
# Legacy anon key (Stack B usaba esta)
SUPABASE_KEY=
# service_role para server Stack A (bypassea RLS)
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PUBLISHABLE_KEY=sb_publishable_gMuIUc-TW3cBMQMXT3Tcfw_OnFQHbs-
# Anon key (público) — usado para flows PKCE en /api/auth/callback.
SUPABASE_ANON_KEY=

# ── Auth (PR1) ──────────────────────────────────────────────────────────────
# false → bypass dev (impersona DEV_BYPASS_EMAIL con DEV_BYPASS_ROLES).
# true  → login obligatorio via magic link + PKCE.
AUTH_ENABLED=false
# Emails que reciben role=admin automáticamente, separados por coma.
ADMIN_EMAILS=julio.lolas@global66.com
# URL pública del sitio (usada para construir redirectTo del magic link).
SITE_URL=https://global66-automation-pao.vercel.app
# Dev bypass (solo cuando AUTH_ENABLED=false)
DEV_BYPASS_EMAIL=dev@global66.com
DEV_BYPASS_ROLES=admin,aprobador,solicitante

# ── Finnecto ────────────────────────────────────────────────────────────────
# REST API: Authorization: Bearer <FINNECTO_API_KEY>
# Docs: https://finnecto-api.readme.io | Base: https://api.finnecto.com
# Generar API key: Administración → Ajustes (hasta 5 keys por cliente)
FINNECTO_BASE_URL=https://api.finnecto.com
FINNECTO_API_KEY=
# Sandbox alternativo: http://sandbox.finnecto.com

# ── Finecto (legacy Stack B — solo si reusás Playwright UI) ─────────────────
FINECTO_URL=
FINECTO_USER=
FINECTO_PASSWORD=

# ── Claude (Anthropic) — usado por ai_edit.js para aplicar comentarios a contratos
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Gemini (Google AI) ──────────────────────────────────────────────────────
# Generar key en https://aistudio.google.com/apikey (free tier disponible)
GEMINI_API_KEY=
# pro = extracción contratos. flash = análisis TC (más barato).
GEMINI_MODEL=gemini-2.5-pro
GEMINI_MODEL_FLASH=gemini-2.5-flash
# Alias aceptado: GOOGLE_API_KEY

# ── Google Workspace (solo Drive — el form es nativo en la plataforma) ─────
GOOGLE_DRIVE_ROOT_FOLDER=
GOOGLE_SERVICE_ACCOUNT_JSON=./secrets/gsa.json

# ── SignNow ─────────────────────────────────────────────────────────────────
SIGNNOW_CLIENT_ID=
SIGNNOW_CLIENT_SECRET=
SIGNNOW_USERNAME=
SIGNNOW_PASSWORD=
SIGNNOW_TEMPLATE_ID=

# ── Resend (email transaccional) ────────────────────────────────────────────
# https://resend.com → free 3k/mes
# Mientras no exista, server loguea mock email a stdout.
RESEND_API_KEY=
# Domain verificado: usar "Global66 Contratos <contratos@global66.com>"
# Mientras DNS no esté listo: "Global66 Contratos <onboarding@resend.dev>"
RESEND_FROM=Global66 Contratos <onboarding@resend.dev>
# Reply-To default: destinatarios responden a este email (no a onboarding@resend.dev).
# Útil mientras dominio no esté verificado.
EMAIL_REPLY_TO=julio.lolas@global66.com

# ── OpenSanctions ───────────────────────────────────────────────────────────
OPENSANCTIONS_API_KEY=

# ── Regcheq (PEP/AML/listas negras — nodo 4 validación proveedores) ─────────
# Docs: https://app.theneo.io/regcheq/external-api
# Key va en URL path: /{endpoint}/{API_KEY}
REGCHEQ_BASE_URL=https://external-api.regcheq.com
REGCHEQ_API_KEY=

# ── n8n / Server ────────────────────────────────────────────────────────────
N8N_WEBHOOK_BASE=https://c204.app.n8n.cloud/webhook
N8N_BASE_URL=https://c204.app.n8n.cloud
SERVER_BASE=http://server:3000
PORT=3000

# ── Notion ──────────────────────────────────────────────────────────────────
NOTION_API_KEY=
NOTION_DB_PROYECTOS=8ee9db22-f903-49b0-bb72-4a9b5722996b
NOTION_DB_TAREAS=3ced4d8e-e89a-4a06-83e7-0cba854f609c
